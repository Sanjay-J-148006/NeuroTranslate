# NeuroTranslate — Environment Variables
# Copy this to .env and fill in your values

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=NeuroTranslate
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./neurotranslate.db
DATABASE_SYNC_URL=sqlite:///./neurotranslate.db

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=1024

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Required to download gated model (ai4bharat/indictrans2-indic-en-dist-200M)
# 1. Accept terms at: https://huggingface.co/ai4bharat/indictrans2-indic-en-dist-200M
# 2. Create a token at: https://huggingface.co/settings/tokens
# 3. Paste it below:
HF_TOKEN=your_huggingface_token_here
